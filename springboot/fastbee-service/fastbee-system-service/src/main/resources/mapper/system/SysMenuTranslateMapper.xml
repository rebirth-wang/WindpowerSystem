<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fastbee.system.mapper.SysMenuTranslateMapper">
    <resultMap type="SysMenuTranslate" id="SysMenuTranslateResult">
        <result property="id"    column="id"    />
        <result property="zhCn"    column="zh_cn"    />
        <result property="enUs"    column="en_us"    />
    </resultMap>

    <sql id="selectSysMenuTranslateVo">
        select id, zh_cn, en_us from sys_menu_translate
    </sql>



</mapper>