{
  "name": "fastbee-smart",
  "private": true,
  "type": "module",
  "version": "3.0.0",
  "description": "FastBee物联网平台",
  "author": "曲靖蜂信科技有限公司",
  "scripts": {
    "dev": "vite",
    "dev:mock": "vite --mode mock",
    "dev:test": "vite --mode test",
    "build": "node --max-old-space-size=8192 ./node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "openapi": "node scripts/openapi-schema.mjs",
    "openapi:check": "node scripts/openapi-schema.mjs --check",
    "check:integration": "node scripts/check-device-phase2-3.mjs && node scripts/check-integration-rollout.mjs && vue-tsc --noEmit -p tsconfig.device-integration.json",
    "verify:integration": "npm run check:integration && npm run test:e2e:integration",
    "test:e2e": "playwright test",
    "test:e2e:integration": "playwright test e2e/request-id.spec.ts e2e/device-management.spec.ts e2e/integration-rollout.spec.ts",
    "test:e2e:ai": "playwright test e2e/midscene-device.spec.ts",
    "test:e2e:main": "playwright test e2e/main-features.spec.ts",
    "test:e2e:debug": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "format": "prettier --write \"src/**/*.{js,ts,vue,json,css,scss}\" \"*.html\" \"*.json\" \"*.ts\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,vue,json,css,scss}\""
  },
