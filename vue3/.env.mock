# Page title
VITE_APP_TITLE = FastBee IoT System

# Mock integration environment
VITE_APP_ENV = 'mock'

# Keep the frontend request prefix stable.
VITE_APP_BASE_API = '/dev-api'

# Apifox local mock default. Replace with the team's Apifox cloud mock URL when available.
VITE_APP_SERVER_API_URL = 'http://127.0.0.1:4523/'

# Mqtt message server URL
VITE_APP_MQTT_SERVER_URL = 'ws://iot.fastbee.cn:8083/mqtt'

# Port
VITE_APP_PORT = 80
